# Enable Powerlevel10k instant prompt (if available)
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Source all files from zshrc.d
if [ -d "$HOME/.config/zsh/zshrc.d" ]; then
  for file in "$HOME/.config/zsh/zshrc.d"/*.zsh; do
    if [ -r "$file" ]; then
      if [ -n "$ZSH_DEBUG" ]; then echo "[ZSHRC] Loading: $(basename "$file")"; fi
      source "$file"
      if [ -n "$ZSH_DEBUG" ]; then echo "[ZSHRC] Loaded:  $(basename "$file")"; fi
    fi
  done
fi


# Load any local customizations
[ -f ~/.zshrc.local ] && source ~/.zshrc.local